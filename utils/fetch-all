#!/usr/bin/perl
# fetch-all: update and build all sv2ghdl-related projects
#
# Usage:
#   fetch-all              # git pull all repos
#   fetch-all status       # git status for all repos
#   fetch-all build        # build all projects
#   fetch-all build -j4    # build all projects (parallel via smak)
#   fetch-all clean        # clean all projects
#   fetch-all rebuild      # clean + build
#   fetch-all rebuild -j4  # clean + build (parallel)
#   fetch-all all          # pull + clean + build
#   fetch-all all -j4      # pull + clean + build (parallel)

use strict;
use warnings;
use Cwd 'abs_path';

my $SRC  = '/usr/local/src';
my $SMAK = "$SRC/smak/smak";

# ── parse args ───────────────────────────────────────────────────────
my $action = shift // 'pull';
my $jobs = 0;
for (@ARGV) { $jobs = $1 if /^-j(\d+)$/; }

my $build_cmd = $jobs > 0 ? "$SMAK -j$jobs" : $SMAK;

# ── repos (git pull targets) ────────────────────────────────────────
my @repos = qw(smak Trilinos xyce nvc iverilog ghdl ltz kestrel sv2ghdl);

# ── buildable projects in dependency order ───────────────────────────
# build_dir is where 'smak' (or 'smak -jN') runs
my @projects = (
    { name => 'Trilinos',  src => "$SRC/Trilinos",  build => "$SRC/Trilinos-Build" },
    { name => 'xyce',      src => "$SRC/xyce",       build => "$SRC/xyce-build",
      deps => ['Trilinos'] },
    { name => 'nvc',       src => "$SRC/nvc",        build => "$SRC/nvc-build" },
    { name => 'iverilog',  src => "$SRC/iverilog",   build => "$SRC/iverilog" },
    { name => 'ghdl',      src => "$SRC/ghdl",       build => "$SRC/ghdl" },
);

# ── helpers ──────────────────────────────────────────────────────────
sub run {
    my ($cmd, $dir) = @_;
    my $pid = fork // die "fork: $!\n";
    if ($pid == 0) {
        chdir($dir) or die "chdir $dir: $!\n" if $dir;
        exec("/bin/sh", "-c", $cmd) or die "exec: $!\n";
    }
    waitpid($pid, 0);
    return $? >> 8;
}

sub banner { printf "\n── %-12s %s ──\n", $_[0], $_[1] // '' }

# ── status ───────────────────────────────────────────────────────────
sub do_status {
    for my $repo (@repos) {
        my $dir = abs_path("$SRC/$repo") // "$SRC/$repo";
        next unless -d "$dir/.git";
        banner($repo);
        run("git status --short --branch", $dir);
    }
}

# ── pull ─────────────────────────────────────────────────────────────
sub do_pull {
    for my $repo (@repos) {
        my $dir = abs_path("$SRC/$repo") // "$SRC/$repo";
        next unless -d "$dir/.git";
        banner($repo, 'pull');
        # detached HEAD (e.g. ghdl) → fetch + reset instead of pull
        my $head = `git -C '$dir' symbolic-ref -q HEAD 2>/dev/null`;
        if ($? != 0) {
            run("git fetch origin && git reset --hard FETCH_HEAD", $dir);
        } else {
            run("git pull", $dir);
        }
    }
}

# ── clean ────────────────────────────────────────────────────────────
sub do_clean {
    for my $proj (@projects) {
        my $bdir = $proj->{build};
        next unless -d $bdir;
        banner($proj->{name}, 'clean');
        run("$build_cmd clean", $bdir);
    }
}

# ── build ────────────────────────────────────────────────────────────
sub do_build {
    my %ok;
    for my $proj (@projects) {
        my $name = $proj->{name};
        my $bdir = $proj->{build};

        unless (-d $bdir) {
            banner($name, 'SKIP (no build dir)');
            next;
        }

        # check deps
        for my $dep (@{$proj->{deps} // []}) {
            unless ($ok{$dep}) {
                banner($name, "SKIP (need $dep)");
                next;
            }
        }

        banner($name, 'build');
        my $rc = run($build_cmd, $bdir);
        if ($rc == 0) {
            $ok{$name} = 1;
            print "  OK\n";
        } else {
            print "  FAILED (exit $rc)\n";
        }
    }

    # summary
    print "\n", "=" x 35, "\n";
    for my $proj (@projects) {
        next unless -d $proj->{build};
        printf "  %-12s %s\n", $proj->{name},
            $ok{$proj->{name}} ? 'OK' : 'FAILED';
    }
    print "=" x 35, "\n";
}

# ── dispatch ─────────────────────────────────────────────────────────
if    ($action eq 'status')  { do_status() }
elsif ($action eq 'pull')    { do_pull() }
elsif ($action eq 'clean')   { do_clean() }
elsif ($action eq 'build')   { do_build() }
elsif ($action eq 'rebuild') { do_clean(); do_build() }
elsif ($action eq 'all')     { do_pull();  do_clean(); do_build() }
else  { die "Usage: fetch-all [status|pull|build|clean|rebuild|all] [-jN]\n" }
