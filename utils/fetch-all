#!/usr/bin/perl
# fetch-all: update and build all sv2ghdl-related projects
#
# Usage:
#   fetch-all              # git status for all repos (default)
#   fetch-all status       # git status for all repos
#   fetch-all list         # list known repos and whether they are present
#   fetch-all url <repo>   # print the upstream URL for <repo>
#   fetch-all build        # build all projects
#   fetch-all build -j4    # build all projects (parallel via smak)
#   fetch-all clean        # clean all projects
#   fetch-all rebuild      # clean + build
#   fetch-all rebuild -j4  # clean + build (parallel)
#   fetch-all all          # pull + clean + build
#   fetch-all all -j4      # pull + clean + build (parallel)

use strict;
use warnings;
use Cwd 'abs_path';

my $SRC  = '/usr/local/src';
my $SMAK = "$SRC/smak/smak";

# ── parse args ───────────────────────────────────────────────────────
my $action = shift // 'status';
my $jobs = 0;
for (@ARGV) { $jobs = $1 if /^-j(\d+)$/; }

my $build_cmd = $jobs > 0 ? "$SMAK -j$jobs" : $SMAK;

# ── repos (git pull targets) ────────────────────────────────────────
my @repos = qw(smak Trilinos xyce nvc iverilog ghdl yosys Nuitka ltz kestrel sv2ghdl);

# Upstream URLs — single source of truth, also consumed by fetch-repo.
my %REPO_URL = (
    smak     => 'https://github.com/kev-cam/smak.git',
    Trilinos => 'https://github.com/trilinos/Trilinos.git',
    xyce     => 'https://github.com/kev-cam/xyce.git',
    nvc      => 'https://github.com/kev-cam/nvc.git',
    iverilog => 'https://github.com/kev-cam/iverilog.git',
    ghdl     => 'https://github.com/kev-cam/ghdl.git',
    yosys    => 'https://github.com/YosysHQ/yosys.git',
    Nuitka   => 'https://github.com/Nuitka/Nuitka.git',
    ltz      => 'https://github.com/kev-cam/ltz.git',
    kestrel  => 'https://github.com/kev-cam/kestrel.git',
    sv2ghdl  => 'https://github.com/kev-cam/sv2ghdl.git',
);

# ── buildable projects in dependency order ───────────────────────────
# build_dir is where 'smak' (or 'smak -jN') runs
my @projects = (
    { name => 'Trilinos',  src => "$SRC/Trilinos",  build => "$SRC/Trilinos-Build" },
    { name => 'xyce',      src => "$SRC/xyce",       build => "$SRC/xyce-build",
      deps => ['Trilinos'] },
    { name => 'nvc',       src => "$SRC/nvc",        build => "$SRC/nvc-build" },
    { name => 'iverilog',  src => "$SRC/iverilog",   build => "$SRC/iverilog" },
    { name => 'ghdl',      src => "$SRC/ghdl",       build => "$SRC/ghdl" },
);

# ── helpers ──────────────────────────────────────────────────────────
sub run {
    my ($cmd, $dir) = @_;
    my $pid = fork // die "fork: $!\n";
    if ($pid == 0) {
        chdir($dir) or die "chdir $dir: $!\n" if $dir;
        exec("/bin/sh", "-c", $cmd) or die "exec: $!\n";
    }
    waitpid($pid, 0);
    return $? >> 8;
}

sub banner { printf "\n── %-12s %s ──\n", $_[0], $_[1] // '' }

# ── status ───────────────────────────────────────────────────────────
sub do_status {
    # Fetch all remotes first so ahead/behind is current
    print "  Fetching remotes...\n";
    for my $repo (@repos) {
        my $dir = abs_path("$SRC/$repo") // "$SRC/$repo";
        next unless -d "$dir/.git";
        `git -C '$dir' fetch --quiet 2>/dev/null`;
    }

    my $fmt = "  %-12s %-25s %3dM  %3dU  %s\n";
    printf "  %-12s %-25s %4s  %4s  %s\n",
        'REPO', 'BRANCH', 'MOD', 'UNT', 'SYNC';
    print "  ", "-" x 72, "\n";
    for my $repo (@repos) {
        my $dir = abs_path("$SRC/$repo") // "$SRC/$repo";
        next unless -d "$dir/.git";

        # branch info
        my $branch = `git -C '$dir' symbolic-ref --short HEAD 2>/dev/null`;
        chomp $branch;
        $branch = '(detached)' unless $branch;
        $branch = substr($branch, 0, 24) . '..' if length($branch) > 25;

        # ahead/behind
        my $sync = '';
        my $ab = `git -C '$dir' rev-list --left-right --count HEAD...\@{upstream} 2>/dev/null`;
        chomp $ab;
        if ($ab =~ /^(\d+)\t(\d+)$/) {
            my ($ahead, $behind) = ($1, $2);
            my @parts;
            push @parts, "ahead $ahead" if $ahead > 0;
            push @parts, "behind $behind" if $behind > 0;
            $sync = join(', ', @parts) || 'up to date';
        } else {
            $sync = 'no upstream';
        }

        # count modified and untracked
        my @lines = `git -C '$dir' status --short 2>/dev/null`;
        my ($mod, $unt) = (0, 0);
        for (@lines) {
            if (/^\?\?/) { $unt++ } else { $mod++ }
        }

        printf $fmt, $repo, $branch, $mod, $unt, $sync;
    }
}

# ── list ─────────────────────────────────────────────────────────────
sub do_list {
    printf "  %-12s  %-8s  %s\n", 'REPO', 'PRESENT', 'PATH';
    print  "  ", "-" x 60, "\n";
    for my $repo (@repos) {
        my $path = "$SRC/$repo";
        my $present = -d "$path/.git" ? 'yes'
                    : -d  $path       ? 'no-git'
                    :                   'no';
        printf "  %-12s  %-8s  %s\n", $repo, $present, $path;
    }
}

# ── url ──────────────────────────────────────────────────────────────
sub do_url {
    my $name = shift;
    die "Usage: fetch-all url <repo>\n" unless defined $name && length $name;
    my $url = $REPO_URL{$name}
        or die "fetch-all: unknown repo '$name' (known: @repos)\n";
    print "$url\n";
}

# ── pull ─────────────────────────────────────────────────────────────
sub do_pull {
    for my $repo (@repos) {
        my $dir = abs_path("$SRC/$repo") // "$SRC/$repo";
        next unless -d "$dir/.git";
        banner($repo, 'pull');
        # detached HEAD (e.g. ghdl) → fetch + reset instead of pull
        my $head = `git -C '$dir' symbolic-ref -q HEAD 2>/dev/null`;
        if ($? != 0) {
            run("git fetch origin && git reset --hard FETCH_HEAD", $dir);
        } else {
            run("git pull", $dir);
        }
    }
}

# ── clean ────────────────────────────────────────────────────────────
sub do_clean {
    for my $proj (@projects) {
        my $bdir = $proj->{build};
        next unless -d $bdir;
        banner($proj->{name}, 'clean');
        run("$build_cmd clean", $bdir);
    }
}

# ── build ────────────────────────────────────────────────────────────
sub do_build {
    my %ok;
    my %elapsed;
    for my $proj (@projects) {
        my $name = $proj->{name};
        my $bdir = $proj->{build};

        unless (-d $bdir) {
            banner($name, 'SKIP (no build dir)');
            next;
        }

        # check deps
        my $deps_met = 1;
        for my $dep (@{$proj->{deps} // []}) {
            unless ($ok{$dep}) {
                banner($name, "SKIP (need $dep)");
                $deps_met = 0;
                last;
            }
        }
        next unless $deps_met;

        banner($name, 'build');
        my $t0 = time();
        my $rc = run($build_cmd, $bdir);
        $elapsed{$name} = time() - $t0;
        if ($rc == 0) {
            $ok{$name} = 1;
            printf "  OK (%ds)\n", $elapsed{$name};
        } else {
            printf "  FAILED (exit %d, %ds)\n", $rc, $elapsed{$name};
        }
    }

    # summary
    print "\n", "=" x 35, "\n";
    for my $proj (@projects) {
        my $name = $proj->{name};
        next unless -d $proj->{build};
        my $t = $elapsed{$name} ? sprintf(" %ds", $elapsed{$name}) : '';
        printf "  %-12s %s%s\n", $name,
            $ok{$name} ? 'OK' : 'FAILED', $t;
    }
    print "=" x 35, "\n";
}

# ── dispatch ─────────────────────────────────────────────────────────
if    ($action eq 'status')  { do_status() }
elsif ($action eq 'list')    { do_list() }
elsif ($action eq 'url')     { do_url(shift @ARGV) }
elsif ($action eq 'pull')    { do_pull() }
elsif ($action eq 'clean')   { do_clean() }
elsif ($action eq 'build')   { do_build() }
elsif ($action eq 'rebuild') { do_clean(); do_build() }
elsif ($action eq 'all')     { do_pull();  do_clean(); do_build() }
else  { die "Usage: fetch-all [status|list|url <repo>|pull|build|clean|rebuild|all] [-jN]\n" }
