# Minimal base image: sv2ghdl source + sshd + the apt-installable build deps
# needed by the rest of the stack. Heavy builds (iverilog/nvc/ghdl/yosys)
# happen at runtime via docker/build_stack.sh, so they can be re-run against
# fresh upstream sources without rebuilding the image.
#
# Build (docker or podman — Containerfile symlink is provided too):
#     docker build -t sv2ghdl-base -f docker/Dockerfile .
#     podman build -t sv2ghdl-base -f docker/Dockerfile .
# Run with sshd + nginx exposed:
#     docker run -d --name sv2ghdl -p 2222:22 -p 8080:80 sv2ghdl-base
#     podman run -d --name sv2ghdl -p 2222:22 -p 8080:80 sv2ghdl-base
# Trigger a clean stack build:
#     ssh -p 2222 root@localhost /opt/sv2ghdl/docker/build_stack.sh
# Export to the host:
#     rsync -av -e 'ssh -p 2222' root@localhost:/home/claude/sv2ghdl-stack/usr/ /tmp/export/
#     sudo rsync -a /tmp/export/ /usr/local/
#
# Default root password is "sv2ghdl" — change it before exposing the port.

FROM ubuntu:22.04

ARG DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
      build-essential automake autoconf libtool pkg-config git ca-certificates \
      flex bison gperf libfl-dev \
      llvm-dev clang \
      libreadline-dev zlib1g-dev libdw-dev libffi-dev libssl-dev \
      check gnat libz3-dev z3 \
      python3 python3-dev python3-pip perl \
      tcl-dev tk-dev libboost-all-dev \
      openssh-server rsync nginx \
      cmake gfortran \
      libopenmpi-dev openmpi-bin \
      libopenblas-dev liblapack-dev \
      libsuitesparse-dev libfftw3-dev \
    && rm -rf /var/lib/apt/lists/*

# sv2ghdl source itself. Cloned from upstream so this Dockerfile is
# standalone — you can `curl` just this file and `docker build .` without
# needing a local checkout. Override SV2GHDL_REPO/SV2GHDL_REF at build time
# to point at a fork or branch.
ARG SV2GHDL_REPO=https://github.com/kev-cam/sv2ghdl.git
ARG SV2GHDL_REF=main
RUN git clone --depth=1 --branch "$SV2GHDL_REF" "$SV2GHDL_REPO" /opt/sv2ghdl \
 && chmod +x /opt/sv2ghdl/docker/build_stack.sh

# sshd setup.
RUN mkdir -p /var/run/sshd \
 && sed -i 's/#PermitRootLogin.*/PermitRootLogin yes/' /etc/ssh/sshd_config \
 && sed -i 's/#PasswordAuthentication.*/PasswordAuthentication yes/' /etc/ssh/sshd_config \
 && echo 'root:sv2ghdl' | chpasswd

# nginx serves docker/index.html on port 80 with the usage instructions.
RUN cp /opt/sv2ghdl/docker/index.html /var/www/html/index.html \
 && sed -i 's|listen 80 default_server;|listen 80 default_server;|' /etc/nginx/sites-enabled/default || true

# Tiny init: launch sshd in the background, nginx in the foreground.
RUN printf '#!/bin/sh\nset -e\n/usr/sbin/sshd\nexec nginx -g "daemon off;"\n' \
    > /usr/local/bin/start.sh && chmod +x /usr/local/bin/start.sh

EXPOSE 22 80
CMD ["/usr/local/bin/start.sh"]
