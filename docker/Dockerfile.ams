# AMS (analog / mixed-signal) build container.
#
# Unlike the other Dockerfiles (which set up a dev box and build the stack at
# RUNTIME via docker/build_stack.sh), this one PREBUILDS the distributed-parallel
# (MPI) Trilinos + Xyce at image-build time, so the result is a ready-to-run
# Xyce-AMS image -- no runtime build, no Trilinos compile on first use.
#
#   need analog / Xyce / mixed-signal cosim?  ->  this image (Dockerfile.ams)
#   need only the digital tools (nvc/ghdl/yosys/iverilog)?  ->  Dockerfile(.debian/.ubuntu22)
#
# Base: Debian Trixie (GCC 14) -- the toolchain Trilinos 14.4 + Xyce compile
# cleanly with; avoids GCC 15's stricter -Wtemplate-body (build_stack.sh -mpi
# has a fallback for newer hosts, but Trixie needs none).
#
# Build:
#   docker build -t sv2ghdl-ams -f docker/Dockerfile.ams .          # nvc + Xyce-MPI (cosim-capable)
#   docker build -t sv2ghdl-ams --build-arg BUILD_MODE=analog \
#                -f docker/Dockerfile.ams .                          # Xyce-MPI only
#   docker run -d --name sv2ghdl-ams -p 2222:22 -p 8080:80 sv2ghdl-ams
# Export the built /usr/local stack onto a host with docker/export.sh.

FROM debian:13

ARG DEBIAN_FRONTEND=noninteractive

# Same toolchain + libs as Dockerfile.debian; the MPI/analog TPLs (openmpi,
# suitesparse/AMD, openblas/lapack, fftw, yaml-cpp) are what Trilinos + Xyce need.
RUN apt-get update && apt-get install -y --no-install-recommends \
      build-essential automake autoconf libtool pkg-config git ca-certificates \
      flex bison gperf libfl-dev \
      llvm-dev clang \
      libreadline-dev zlib1g-dev libzstd-dev libdw-dev libffi-dev libssl-dev \
      check gnat libz3-dev z3 \
      python3 python3-dev python3-pip python3-sympy perl \
      tcl-dev tk-dev libboost-all-dev \
      openssh-server rsync nginx \
      gfortran curl \
      libopenmpi-dev openmpi-bin \
      libopenblas-dev liblapack-dev \
      libsuitesparse-dev libfftw3-dev libyaml-cpp-dev libginac-dev \
    && rm -rf /var/lib/apt/lists/*

ARG SV2GHDL_SRC=git
ARG SV2GHDL_REPO=https://github.com/kev-cam/sv2ghdl.git
ARG SV2GHDL_REF=main
COPY . /tmp/sv2ghdl-ctx
RUN if [ "$SV2GHDL_SRC" = "local" ]; then \
        cp -a /tmp/sv2ghdl-ctx /opt/sv2ghdl; \
    else \
        git clone --depth=1 --branch "$SV2GHDL_REF" "$SV2GHDL_REPO" /opt/sv2ghdl; \
    fi \
 && rm -rf /tmp/sv2ghdl-ctx \
 && chmod +x /opt/sv2ghdl/docker/build_stack.sh

# Prebuild the MPI stack now (runs as user 'claude' under ~claude, then rsync'd
# to /usr/local). BUILD_MODE: 'full' = digital tools (nvc/ghdl/yosys) + Xyce-MPI
# for mixed-signal cosim; 'analog' = Xyce-MPI only.
ARG BUILD_MODE=full
RUN /opt/sv2ghdl/docker/build_stack.sh ${BUILD_MODE} -mpi

RUN mkdir -p /var/run/sshd \
 && sed -i 's/#PermitRootLogin.*/PermitRootLogin yes/' /etc/ssh/sshd_config \
 && sed -i 's/#PasswordAuthentication.*/PasswordAuthentication yes/' /etc/ssh/sshd_config \
 && echo 'root:sv2ghdl' | chpasswd

RUN cp /opt/sv2ghdl/docker/index.html /var/www/html/index.html \
 && sed -i 's|listen 80 default_server;|listen 80 default_server;|' /etc/nginx/sites-enabled/default || true

RUN printf '#!/bin/sh\nset -e\n/usr/sbin/sshd\nexec nginx -g "daemon off;"\n' \
    > /usr/local/bin/start.sh && chmod +x /usr/local/bin/start.sh

EXPOSE 22 80
CMD ["/usr/local/bin/start.sh"]
