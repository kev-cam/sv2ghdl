#!/bin/bash
#
# verilator-sv2ghdl - verilator-compatible wrapper for sv2ghdl + NVC
#
# Translates a subset of verilator's CLI into the sv2ghdl/NVC pipeline:
#   verilator --binary -o sim top.sv          → svx pipeline (single binary)
#   verilator --cc --main --exe ... -f files  → RTLMeter-style compile flow
#
# RTLMeter compile flow (--cc): RTLMeter shells out to
#   verilator --cc --main --exe --timing --quiet-stats -Wno-fatal \
#             --prefix Vsim --top-module TOP +incdir+DIR +define+K=V -f filelist
# then `make -C obj_dir -f Vsim.mk`, then runs `obj_dir/Vsim +plusargs`.
# We translate the filelist to VHDL (via nvc -a, which invokes
# iverilog-sv2ghdl internally), elaborate with nvc -e, and drop an
# `obj_dir/Vsim` script that runs `nvc -r` plus a no-op `Vsim.mk` so the
# downstream `make` step is satisfied.  The cycle-count / TEST_PASSED
# contract is met by the design's own $fopen("_rtlmeter_cycles.txt") and
# $display, which nvc -r executes in the (execute) cwd.
#
# On unsupported input the script exec's the real verilator (set
# VERILATOR=/path/to/verilator to override discovery).  In --cc mode a
# translation/analyse/elaborate FAILURE is reported (non-zero exit) rather
# than silently falling through, so sv2ghdl/nvc gaps surface — set
# SVX_CC_FALLTHROUGH=1 to fall through to real verilator on failure instead.
#

set -o pipefail
export PATH="/usr/bin:/usr/local/bin:/bin:$PATH"

SCRIPT_DIR="${BASH_SOURCE[0]%/*}/.."
SV2GHDL="$SCRIPT_DIR/sv2ghdl.pl"

if [[ -z "$NVC" ]]; then
    if [[ -x /usr/local/src/nvc-build/bin/nvc ]]; then NVC=/usr/local/src/nvc-build/bin/nvc; else NVC=nvc; fi
fi
VERILATOR="${VERILATOR:-verilator}"
SVX_STD="${SVX_STD:-2040}"

# Resolve NVC libdir the same way iverilog-sv2ghdl does
if [[ -z "$NVC_LIBDIR" ]]; then
    _nvc_bin=$(command -v "$NVC" 2>/dev/null)
    if [[ -n "$_nvc_bin" ]]; then
        _nvc_bin=$(readlink -f "$_nvc_bin")
        _nvc_prefix="${_nvc_bin%/bin/nvc}"
        if [[ -d "$_nvc_prefix/lib/sv2vhdl" ]]; then
            NVC_LIBDIR="$_nvc_prefix/lib"
        elif [[ -d "$_nvc_prefix/lib/nvc/sv2vhdl" ]]; then
            NVC_LIBDIR="$_nvc_prefix/lib/nvc"
        else
            NVC_LIBDIR="$_nvc_prefix/lib/nvc"
        fi
    else
        NVC_LIBDIR="/usr/local/lib/nvc"
    fi
fi

ORIG_ARGS=("$@")

fallthrough() {
    local reason="$1"
    [[ -n "$SVX_VERBOSE" ]] && echo "verilator-sv2ghdl: falling through to $VERILATOR ($reason)" >&2
    exec "$VERILATOR" "${ORIG_ARGS[@]}"
}

BINARY=0
CC=0
OUTPUT=""
TOP_MODULE=""
PREFIX="Vsim"
MDIR=""
SOURCES=()
INCDIRS=()
DEFINES=()
FILELISTS=()
ORIG_DIR="$(pwd)"

abspath() {
    case "$1" in
        /*) printf '%s' "$1" ;;
        *)  printf '%s/%s' "$ORIG_DIR" "$1" ;;
    esac
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        --binary)             BINARY=1;        shift ;;
        --cc|--exe|--main)    CC=1;            shift ;;
        --build)              shift ;;          # build implied; ignore
        -o)                   OUTPUT="$2";     shift 2 ;;
        --top|--top-module)   TOP_MODULE="$2"; shift 2 ;;
        --prefix)             PREFIX="$2";     shift 2 ;;
        --Mdir)               MDIR="$2";       shift 2 ;;
        -f)                   FILELISTS+=("$2"); shift 2 ;;
        -j)                   shift 2 ;;        # parallelism — ignored
        -j*)                  shift ;;
        -Wall|-Wno-*|-Wpedantic|--quiet|--quiet-stats|--quiet-exit) shift ;;
        -sv|--sv)             shift ;;          # SV mode default
        --timing|--no-timing) shift ;;
        --autoflush|--trace|--trace-vcd|--trace-fst) shift ;;
        --trace-structs|--trace-params) shift ;;
        -CFLAGS|-LDFLAGS|-MAKEFLAGS) shift 2 ;;
        +define+*)            DEFINES+=("${1#+define+}"); shift ;;
        -D*)                  DEFINES+=("${1#-D}");       shift ;;
        +incdir+*)            INCDIRS+=("${1#+incdir+}"); shift ;;
        -I*)                  INCDIRS+=("${1#-I}");       shift ;;
        --lint-only)
            CC=1; shift ;;                       # treat as compile/analyse only
        -V|--version)
            echo "Verilator 5.0.0 (sv2ghdl/nvc)"; exit 0 ;;
        +*)                   shift ;;           # other +plusargs — ignored
        -*)
            if [[ $CC -eq 1 || $BINARY -eq 1 ]]; then
                shift                            # tolerate unknown flags in our modes
            else
                fallthrough "unknown flag $1"
            fi ;;
        *)
            SOURCES+=("$1"); shift ;;
    esac
done

# ---------------------------------------------------------------------------
# RTLMeter / --cc compile flow
# ---------------------------------------------------------------------------
if [[ $CC -eq 1 ]]; then
    cc_fail() {
        local reason="$1"
        if [[ -n "$SVX_CC_FALLTHROUGH" ]]; then
            fallthrough "cc: $reason"
        fi
        echo "verilator-sv2ghdl: --cc flow failed: $reason" >&2
        exit 1
    }

    # Expand any -f filelists (one path per line, '#' comments ignored).
    FILES=()
    for fl in "${FILELISTS[@]}"; do
        fl_abs="$(abspath "$fl")"
        [[ -r "$fl_abs" ]] || cc_fail "cannot read filelist $fl"
        while IFS= read -r line; do
            line="${line%%#*}"
            line="${line#"${line%%[![:space:]]*}"}"   # ltrim
            line="${line%"${line##*[![:space:]]}"}"   # rtrim
            [[ -z "$line" ]] && continue
            FILES+=("$line")
        done < "$fl_abs"
    done
    FILES+=("${SOURCES[@]}")

    # Keep only Verilog source files (.v/.sv); include files (.vh/.svh/.h/.svi)
    # are found via -I, not compiled directly.
    SRCV=()
    for f in "${FILES[@]}"; do
        case "$f" in
            *.v|*.sv) SRCV+=("$(abspath "$f")") ;;
            *) ;;
        esac
    done
    [[ ${#SRCV[@]} -gt 0 ]] || cc_fail "no Verilog source files"

    # Top module
    [[ -n "$TOP_MODULE" ]] || cc_fail "no --top-module"

    # Output dir for the verilator-style artefacts (obj_dir by default)
    [[ -n "$MDIR" ]] || MDIR="obj_dir"
    MDIR_ABS="$(abspath "$MDIR")"
    mkdir -p "$MDIR_ABS"

    # NVC work library (persists for -e and -r). With --std=2040 NVC requires
    # the library directory name to end in '.40', so name it accordingly.
    if [[ "$SVX_STD" == "2040" ]]; then
        WORK="$MDIR_ABS/${PREFIX}.40"
    else
        WORK="$MDIR_ABS/${PREFIX}.nvcwork"
    fi
    rm -rf "$WORK"

    # Include-dir and define args (analyse-stage options, after -a). nvc
    # forwards these to the batch sv2ghdl/iverilog translation.
    IARGS=()
    for d in "${INCDIRS[@]}"; do IARGS+=("-I" "$(abspath "$d")"); done
    DARGS=()
    for kv in "${DEFINES[@]}"; do DARGS+=("-D" "$kv"); done

    # Resolve through any symlink (RTLMeter invokes us via a `verilator`
    # symlink), so sibling tools (iverilog-sv2ghdl, gen-veer-tb) are found.
    BINDIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
    ELAB_TOP="$TOP_MODULE"

    # VeeR special-case: RTLMeter's tb_top.sv uses testbench SV the iverilog
    # frontend can't translate, so tb_top stubs and the design runs 0 cycles.
    # Instead, translate the synthesizable RTL and drive veer_wrapper with a
    # generated VHDL testbench (gen-veer-tb): clock/reset + AXI memory model +
    # program.hex load + magic-mailbox TEST_PASSED and _rtlmeter_cycles.txt.
    # Detect the VeeR top wrapper. EH1 names it `veer_wrapper`; EH2/EL2 use a
    # family prefix (`eh2_veer_wrapper` / `el2_veer_wrapper`). Prefer the
    # prefixed name when present (EL2 also ships a thin `veer_wrapper` shim).
    VEER_WRAPPER=""
    for _cand in veer_wrapper eh2_veer_wrapper el2_veer_wrapper; do
        if grep -qsE "module[[:space:]]+${_cand}\b" "${SRCV[@]}"; then
            VEER_WRAPPER="$_cand"
        fi
    done
    if [[ -n "$VEER_WRAPPER" ]]; then
        echo "verilator-sv2ghdl: VeeR design -- driving $VEER_WRAPPER via gen-veer-tb" >&2
        XLAT="$MDIR_ABS/${PREFIX}_xlat"
        rm -rf "$XLAT"
        # Explicit translation so we get design.vhd (gen-veer-tb reads the
        # wrapper entity ports from it) + an analysed work library.
        "$BINDIR/iverilog-sv2ghdl" -o "$XLAT" "${IARGS[@]}" "${DARGS[@]}" "${SRCV[@]}" >&2 \
            || cc_fail "iverilog-sv2ghdl translation failed"
        [[ -s "$XLAT/design.vhd" ]] || cc_fail "no design.vhd from translation"
        "$BINDIR/gen-veer-tb" "$XLAT/design.vhd" "$VEER_WRAPPER" > "$XLAT/veer_eh1_tb.vhd" \
            || cc_fail "gen-veer-tb failed ($VEER_WRAPPER not translated with ports? check build-area iverilog)"
        WORK="$XLAT/work"
        "$NVC" -M 1g --std="$SVX_STD" --work="$WORK" -L "$NVC_LIBDIR" -a "$XLAT/veer_eh1_tb.vhd" \
            || cc_fail "nvc -a (veer tb) failed"
        "$NVC" -M 1g --std="$SVX_STD" --work="$WORK" -L "$NVC_LIBDIR" -e veer_eh1_tb \
            || cc_fail "nvc -e veer_eh1_tb failed"
        ELAB_TOP="veer_eh1_tb"
    else
        echo "verilator-sv2ghdl: analysing ${#SRCV[@]} Verilog files via nvc (top=$TOP_MODULE)" >&2
        "$NVC" -M 1g --std="$SVX_STD" --work="$WORK" -L "$NVC_LIBDIR" \
            -a "${IARGS[@]}" "${DARGS[@]}" "${SRCV[@]}" \
            || cc_fail "nvc -a failed"

        echo "verilator-sv2ghdl: elaborating $TOP_MODULE" >&2
        "$NVC" -M 1g --std="$SVX_STD" --work="$WORK" -L "$NVC_LIBDIR" -e "$TOP_MODULE" \
            || cc_fail "nvc -e failed"
    fi

    # Emit obj_dir/<PREFIX> as the "simulator binary": runs nvc -r in the
    # caller's cwd (the execute dir), forwarding any +plusargs.
    SIMBIN="$MDIR_ABS/$PREFIX"
    cat > "$SIMBIN" <<EOF
#!/bin/bash
# Generated by verilator-sv2ghdl (--cc) — runs nvc against the elaborated lib.
exec "$NVC" -M 1g --std=$SVX_STD --work="$WORK" -L "$NVC_LIBDIR" -r "$ELAB_TOP" "\$@"
EOF
    chmod +x "$SIMBIN"

    # No-op makefile so RTLMeter's `make -C obj_dir -f <PREFIX>.mk` succeeds
    # (the "binary" is already built above).
    cat > "$MDIR_ABS/${PREFIX}.mk" <<EOF
# Generated by verilator-sv2ghdl (--cc): the simulator is prebuilt.
.PHONY: all default
all default:
	@true
EOF

    exit 0
fi

# ---------------------------------------------------------------------------
# --binary flow (single self-contained run)
# ---------------------------------------------------------------------------
[[ $BINARY -eq 1 ]]                || fallthrough "no --binary"
[[ ${#SOURCES[@]} -gt 0 ]]          || fallthrough "no sources"

# Absolute source paths
ABS_SOURCES=()
for src in "${SOURCES[@]}"; do
    ABS_SOURCES+=("$(abspath "$src")")
done

# Top module — derive from last source if not given
if [[ -z "$TOP_MODULE" ]]; then
    LAST="${ABS_SOURCES[${#ABS_SOURCES[@]}-1]}"
    TOP_MODULE=$(grep -m1 -oP '^\s*module\s+\K\w+' "$LAST" 2>/dev/null)
fi
[[ -n "$TOP_MODULE" ]] || fallthrough "cannot determine top"

# Output path — verilator default is obj_dir/V<top>
if [[ -z "$OUTPUT" ]]; then
    mkdir -p "$ORIG_DIR/obj_dir"
    OUTPUT="$ORIG_DIR/obj_dir/V$TOP_MODULE"
fi
OUTBIN="$(abspath "$OUTPUT")"

WORKDIR="${OUTBIN}.svx"
rm -rf "$WORKDIR"
mkdir -p "$WORKDIR"

# Translate each source with sv2ghdl.pl
VHDL_FILES=()
for src in "${ABS_SOURCES[@]}"; do
    base="${src##*/}"; base="${base%.*}"
    out="$WORKDIR/${base}.vhd"
    if ! "$SV2GHDL" "$src" -o "$out" 2>/dev/null || [[ ! -s "$out" ]]; then
        fallthrough "sv2ghdl failed on $src"
    fi
    VHDL_FILES+=("$out")
done

# Analyse + elaborate with NVC
cd "$WORKDIR"
for vhd in "${VHDL_FILES[@]}"; do
    "$NVC" --std=${SVX_STD} -L "$NVC_LIBDIR" -a "$vhd" || fallthrough "nvc -a failed"
done
"$NVC" --std=${SVX_STD} -L "$NVC_LIBDIR" -e "$TOP_MODULE" || fallthrough "nvc -e failed"

# Emit a runner script as the "binary"
cat > "$OUTBIN" <<EOF
#!/bin/bash
cd "${WORKDIR}" && exec "${NVC}" --std=${SVX_STD} -L "${NVC_LIBDIR}" -r "${TOP_MODULE}" "\$@"
EOF
chmod +x "$OUTBIN"

exit 0
