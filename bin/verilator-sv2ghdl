#!/bin/bash
#
# verilator-sv2ghdl - verilator-compatible wrapper for sv2ghdl + NVC
#
# Translates a subset of verilator's CLI into the sv2ghdl/NVC pipeline:
#   verilator --binary -o sim top.sv      → svx pipeline
#   verilator --cc ...                    → falls through to real verilator
#
# On any unsupported flag, or if translation/compilation fails, this script
# exec's the real verilator (set VERILATOR=/path/to/verilator to override
# discovery).
#
# Output of --binary mode is a small shell script at -o NAME (or
# obj_dir/V<top>) that re-runs nvc -r against the elaborated work library.
#

set -o pipefail
export PATH="/usr/bin:/usr/local/bin:/bin:$PATH"

SCRIPT_DIR="${BASH_SOURCE[0]%/*}/.."
SV2GHDL="$SCRIPT_DIR/sv2ghdl.pl"

NVC="${NVC:-nvc}"
VERILATOR="${VERILATOR:-verilator}"

# Resolve NVC libdir the same way iverilog-sv2ghdl does
if [[ -z "$NVC_LIBDIR" ]]; then
    _nvc_bin=$(command -v "$NVC" 2>/dev/null)
    if [[ -n "$_nvc_bin" ]]; then
        _nvc_bin=$(readlink -f "$_nvc_bin")
        _nvc_prefix="${_nvc_bin%/bin/nvc}"
        if [[ -d "$_nvc_prefix/lib/sv2vhdl" ]]; then
            NVC_LIBDIR="$_nvc_prefix/lib"
        elif [[ -d "$_nvc_prefix/lib/nvc/sv2vhdl" ]]; then
            NVC_LIBDIR="$_nvc_prefix/lib/nvc"
        else
            NVC_LIBDIR="$_nvc_prefix/lib/nvc"
        fi
    else
        NVC_LIBDIR="/usr/local/lib/nvc"
    fi
fi

fallthrough() {
    local reason="$1"
    [[ -n "$SVX_VERBOSE" ]] && echo "verilator-sv2ghdl: falling through to $VERILATOR ($reason)" >&2
    exec "$VERILATOR" "${ORIG_ARGS[@]}"
}

ORIG_ARGS=("$@")

BINARY=0
OUTPUT=""
TOP_MODULE=""
SOURCES=()
ORIG_DIR="$(pwd)"

while [[ $# -gt 0 ]]; do
    case "$1" in
        --binary)             BINARY=1;        shift ;;
        -o)                   OUTPUT="$2";     shift 2 ;;
        --top|--top-module)   TOP_MODULE="$2"; shift 2 ;;
        -j)                   shift 2 ;;        # parallelism — ignored
        -j*)                  shift ;;
        -Wall|-Wno-*|-Wpedantic|--quiet|--quiet-exit) shift ;;
        -sv|--sv)             shift ;;          # SV mode default
        --timing|--no-timing) shift ;;
        -CFLAGS|-LDFLAGS)     shift 2 ;;
        -D*|+define+*)        shift ;;          # passed-through unsupported
        -I*|+incdir+*)        shift ;;
        --cc|--exe|--lint-only|--Mdir|--build|--main)
            fallthrough "unsupported flag $1" ;;
        -V|--version)
            echo "Verilator 5.0.0 (sv2ghdl/nvc)"; exit 0 ;;
        -*)
            fallthrough "unknown flag $1" ;;
        *)
            SOURCES+=("$1"); shift ;;
    esac
done

[[ $BINARY -eq 1 ]]                || fallthrough "no --binary"
[[ ${#SOURCES[@]} -gt 0 ]]          || fallthrough "no sources"

# Absolute source paths
ABS_SOURCES=()
for src in "${SOURCES[@]}"; do
    case "$src" in
        /*) ABS_SOURCES+=("$src") ;;
        *)  ABS_SOURCES+=("$ORIG_DIR/$src") ;;
    esac
done

# Top module — derive from last source if not given
if [[ -z "$TOP_MODULE" ]]; then
    LAST="${ABS_SOURCES[${#ABS_SOURCES[@]}-1]}"
    TOP_MODULE=$(grep -m1 -oP '^\s*module\s+\K\w+' "$LAST" 2>/dev/null)
fi
[[ -n "$TOP_MODULE" ]] || fallthrough "cannot determine top"

# Output path — verilator default is obj_dir/V<top>
if [[ -z "$OUTPUT" ]]; then
    mkdir -p "$ORIG_DIR/obj_dir"
    OUTPUT="$ORIG_DIR/obj_dir/V$TOP_MODULE"
fi
case "$OUTPUT" in
    /*) OUTBIN="$OUTPUT" ;;
    *)  OUTBIN="$ORIG_DIR/$OUTPUT" ;;
esac

WORKDIR="${OUTBIN}.svx"
rm -rf "$WORKDIR"
mkdir -p "$WORKDIR"

# Translate each source with sv2ghdl.pl
VHDL_FILES=()
for src in "${ABS_SOURCES[@]}"; do
    base="${src##*/}"; base="${base%.*}"
    out="$WORKDIR/${base}.vhd"
    if ! "$SV2GHDL" "$src" -o "$out" 2>/dev/null || [[ ! -s "$out" ]]; then
        fallthrough "sv2ghdl failed on $src"
    fi
    VHDL_FILES+=("$out")
done

# Analyse + elaborate with NVC
cd "$WORKDIR"
for vhd in "${VHDL_FILES[@]}"; do
    "$NVC" --std=2008 -L "$NVC_LIBDIR" -a "$vhd" || fallthrough "nvc -a failed"
done
"$NVC" --std=2008 -L "$NVC_LIBDIR" -e "$TOP_MODULE" || fallthrough "nvc -e failed"

# Emit a runner script as the "binary"
cat > "$OUTBIN" <<EOF
#!/bin/bash
# Generated by verilator-sv2ghdl — runs nvc against pre-elaborated work lib
exec "${NVC}" --std=2008 -L "${NVC_LIBDIR}" -r "${TOP_MODULE}" "\$@"
EOF
# The work library lives in $WORKDIR; cd there before running.
# Wrap with a stub that cds first.
mv "$OUTBIN" "${OUTBIN}.run"
cat > "$OUTBIN" <<EOF
#!/bin/bash
cd "${WORKDIR}" && exec "${NVC}" --std=2008 -L "${NVC_LIBDIR}" -r "${TOP_MODULE}" "\$@"
EOF
chmod +x "$OUTBIN"
rm -f "${OUTBIN}.run"

exit 0
