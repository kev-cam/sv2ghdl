#!/bin/bash
#
# sv2vhdl-modules — Per-module Verilog-to-VHDL translation
#
# Translates each Verilog module individually, emitting VHDL entity+
# architecture for modules that succeed and stub entities with
# foreign architecture attributes for modules that fail.
#
# Usage: sv2vhdl-modules [options] input.sv -o output.vhd
#
# Options:
#   -I dir          Include directory (passed to iverilog)
#   --top module    Top module name (emitted last)
#
# Pipeline position:
#   iverilog -E | sv-normalize | sv2vhdl-modules > design.vhd
#

set -o pipefail

SCRIPT_DIR="${BASH_SOURCE[0]%/*}"
[[ "$SCRIPT_DIR" == "${BASH_SOURCE[0]}" ]] && SCRIPT_DIR="."

# Default to the BUILD-AREA iverilog + its plugin dir, so we validate what we
# build before installing. Falling back to a system `iverilog` with a stale
# -B silently fails every module's SV->VHDL translation -> port-less deferred
# stubs (a whole design that elaborates hollow). $IVERILOG / $IVL_BUILD_LIB
# still override.
if [[ -z "$IVERILOG" ]]; then
    if [[ -x /usr/local/src/iverilog/_install/bin/iverilog ]]; then
        IVERILOG=/usr/local/src/iverilog/_install/bin/iverilog
    else
        IVERILOG=iverilog
    fi
fi
if [[ -z "$IVL_BUILD_LIB" ]]; then
    _ivl_pfx="${IVERILOG%/bin/iverilog}"
    if [[ -d "$_ivl_pfx/lib/ivl" ]]; then
        IVL_BUILD_LIB="$_ivl_pfx/lib/ivl"
    elif [[ -d /usr/local/src/iverilog/_install/lib/ivl ]]; then
        IVL_BUILD_LIB=/usr/local/src/iverilog/_install/lib/ivl
    else
        IVL_BUILD_LIB=/usr/local/src/iverilog/build-lib
    fi
fi
IVL_FLAGS="-B$IVL_BUILD_LIB"
NVC_FLAGS="-psv2vhdl=1 -g2012"
OUTFILE=""
TOPMOD=""
INFILE=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        -o)     OUTFILE="$2"; shift 2 ;;
        --top)  TOPMOD="$2"; shift 2 ;;
        -I*)    IVL_FLAGS="$IVL_FLAGS $1"; shift ;;
        -*)     shift ;;
        *)      INFILE="$1"; shift ;;
    esac
done

if [[ -z "$INFILE" ]]; then
    echo "Usage: sv2vhdl-modules input.sv -o output.vhd" >&2
    exit 1
fi

WORKDIR=$(mktemp -d)
trap "rm -rf $WORKDIR" EXIT

# Extract module names
MODULES=$(grep "^module " "$INFILE" | sed 's/module //; s/[( ;#].*//' | sort -u)
NMOD=$(echo "$MODULES" | wc -w)
echo "sv2vhdl-modules: found $NMOD modules" >&2

PASS=0
FAIL=0
STUB=0

# Translate each module
for mod in $MODULES; do
    [[ "$mod" == "__rtlmeter_utils" ]] && continue

    MODFILE="$WORKDIR/${mod}.vhd"

    # Per-module translate timeout. Large modules like VeeR's veer_wrapper
    # take ~130s; 120s was too tight and silently deferred them to a
    # port-less stub (which a VHDL testbench then can't port-map). Allow
    # override via SV2VHDL_MOD_TIMEOUT; default raised to 600s.
    if timeout "${SV2VHDL_MOD_TIMEOUT:-600}" "$IVERILOG" $IVL_FLAGS -tvhdl $NVC_FLAGS \
            -s "$mod" -o "$MODFILE" "$INFILE" >/dev/null 2>&1; then
        if [[ -s "$MODFILE" ]]; then
            # Rename helper entities by port-signature hash so cross-module
            # collisions (e.g. rvdff5 with different WIDTHs) become distinct
            # names. Leave the user's module name un-renamed so elaboration
            # commands stay stable.
            RENAMED="$WORKDIR/${mod}_renamed.vhd"
            if "${SCRIPT_DIR:-$(dirname "$0")}/sv-rename-variants" \
                    "$MODFILE" -o "$RENAMED" --top "$mod" 2>/dev/null; then
                mv "$RENAMED" "$MODFILE"
            fi
            PASS=$((PASS + 1))
        else
            FAIL=$((FAIL + 1))
            MODFILE=""
        fi
    else
        FAIL=$((FAIL + 1))
        MODFILE=""
    fi

    # Generate stub for failed modules
    if [[ -z "$MODFILE" ]]; then
        MODFILE="$WORKDIR/${mod}_stub.vhd"
        # Extract port declarations from the Verilog source
        # For now, emit a minimal stub — the foreign plugin will
        # do the real compilation at elaboration time
        # Extract ports from the translated modules that reference this one,
        # or emit a port-less stub. The deferred plugin will replace it.
        cat > "$MODFILE" << STUBEOF
-- Deferred compilation stub for module $mod
-- Source: $INFILE
library ieee;
use ieee.std_logic_1164.all;
library sv2vhdl;
use sv2vhdl.logic3d_types_pkg.all;

entity ${mod} is
  -- sv2vhdl:deferred source=${INFILE} module=${mod}
end entity;

architecture stub of ${mod} is
begin
  -- Deferred: will be compiled with concrete parameters at elaboration time
end architecture;
STUBEOF
        STUB=$((STUB + 1))
    fi
done

echo "sv2vhdl-modules: $PASS translated, $FAIL failed ($STUB stubs)" >&2

# Concatenate all VHDL files (stubs first, then translated, top last)
{
    # Stubs first
    for f in "$WORKDIR"/*_stub.vhd; do
        [[ -f "$f" ]] && cat "$f" && echo
    done
    # Translated modules (not top)
    for f in "$WORKDIR"/*.vhd; do
        [[ "$f" == *_stub.vhd ]] && continue
        [[ -n "$TOPMOD" && "$f" == *"${TOPMOD}.vhd" ]] && continue
        [[ -f "$f" ]] && cat "$f" && echo
    done
    # Top module last
    if [[ -n "$TOPMOD" && -f "$WORKDIR/${TOPMOD}.vhd" ]]; then
        cat "$WORKDIR/${TOPMOD}.vhd"
    fi
} > "${OUTFILE:-/dev/stdout}"
