#!/usr/bin/perl
# sv-flatten-pkg — flatten SV struct parameters and struct-typed ports
#
# Usage: sv-flatten-pkg --pkg=preprocessed.v [--struct=NAME] [--param=NAME] input.v
#
# 1. Parses ALL typedef struct packed from the package
# 2. Decodes the packed struct parameter hex literal, replaces pt.FIELD with integers
# 3. Strips #(...) parameter blocks and import lines
# 4. Expands struct-typed ports into individual logic ports
#
# Output goes to stdout.

use strict;
use warnings;
use Math::BigInt;

my ($pkg_file, $struct_name, $param_name) = ('', 'el2_param_t', 'pt');
my @inputs;

for my $arg (@ARGV) {
    if ($arg =~ /^--pkg=(.+)/)    { $pkg_file = $1; }
    elsif ($arg =~ /^--struct=(.+)/) { $struct_name = $1; }
    elsif ($arg =~ /^--param=(.+)/)  { $param_name = $1; }
    elsif ($arg !~ /^-/)             { push @inputs, $arg; }
}

die "Usage: sv-flatten-pkg --pkg=FILE [--struct=NAME] [--param=NAME] input.v\n"
    unless $pkg_file && @inputs;

# Step 1: Parse ALL struct typedefs from the package
open my $pfh, '<', $pkg_file or die "open $pkg_file: $!\n";
my %structs;  # type_name => [{name, width, type}]
my $cur_struct = '';
while (<$pfh>) {
    if (/typedef\s+struct\s+packed\s*\{/) {
        $cur_struct = '_pending';
        next;
    }
    if ($cur_struct && /^\s*\}\s*(\w+)\s*;/) {
        $structs{$1} = $structs{$cur_struct} if $cur_struct eq '_pending';
        $cur_struct = '';
        # Re-key if pending
        if (exists $structs{'_pending'}) {
            $structs{$1} = delete $structs{'_pending'};
        }
        next;
    }
    if ($cur_struct) {
        my $s = ($cur_struct eq '_pending') ? '_pending' : $cur_struct;
        $structs{$s} //= [];
        if (/^\s*logic\s+\[(\d+):(\d+)\]\s+(\w+)/) {
            push @{$structs{$s}}, { name => $3, width => $1 - $2 + 1, type => 'logic' };
        } elsif (/^\s*logic\s+(\w+)/ && !/\[/) {
            push @{$structs{$s}}, { name => $1, width => 1, type => 'logic' };
        } elsif (/^\s*(\w+)\s+(\w+)\s*;/ && $1 ne 'logic') {
            push @{$structs{$s}}, { name => $2, width => 0, type => $1, opaque => 1 };
        }
    }
}
close $pfh;

# Compute total width for the param struct
my $total_bits = 0;
if (exists $structs{$struct_name}) {
    $total_bits += $_->{width} for @{$structs{$struct_name}};
}

# Step 2: Process each input file
for my $input (@inputs) {
    open my $ifh, '<', $input or die "open $input: $!\n";
    my @lines = <$ifh>;
    close $ifh;

    # Find the hex parameter value
    my $hex_value;
    my %field_values;
    for my $line (@lines) {
        if ($line =~ /parameter\s+$struct_name\s+$param_name\s*=\s*\d+'h([0-9A-Fa-f]+)/) {
            $hex_value = $1;
            last;
        }
    }

    if ($hex_value && exists $structs{$struct_name}) {
        my $bigval = Math::BigInt->new("0x$hex_value");
        my $bit_offset = $total_bits;
        for my $f (@{$structs{$struct_name}}) {
            next if $f->{opaque};
            $bit_offset -= $f->{width};
            my $mask = Math::BigInt->new(1)->blsft($f->{width})->bsub(1);
            my $val = $bigval->copy()->brsft($bit_offset)->band($mask);
            $field_values{$f->{name}} = $val->numify();
        }
    }

    my $in_param_block = 0;
    my $paren_depth = 0;
    my @outbuf;  # Buffer output for post-processing

    for my $line (@lines) {
        # Remove import lines
        next if $line =~ /^\s*import\s/;

        # Strip #( ... ) parameter block
        if ($line =~ /^\s*#\s*\(/) {
            $in_param_block = 1;
            $paren_depth = 1;
            next;
        }
        if ($in_param_block) {
            for my $ch (split //, $line) {
                if ($ch eq '(') { $paren_depth++; }
                elsif ($ch eq ')') {
                    $paren_depth--;
                    if ($paren_depth <= 0) {
                        $in_param_block = 0;
                        (undef, my $rest) = split /\)/, $line, 2;
                        push @outbuf, "(\n" if defined $rest && $rest =~ /\(/;
                        last;
                    }
                }
            }
            next;
        }

        # Expand struct-typed ports:
        # input el2_br_pkt_t name,  →  input logic name_valid, input logic [11:0] name_toffset, ...
        # Also handles arrays: input el2_trigger_pkt_t [3:0] name
        if ($line =~ /^\s*(input|output|inout)\s+(el2_\w+_t)\s+(?:\[([^\]]+)\]\s+)?(\w+)\s*([,;)]?)/) {
            my ($dir, $stype, $array_range, $port_name, $term) = ($1, $2, $3, $4, $5);
            # Default to comma — the original term may be empty if the struct port
            # is followed by more ports. Only use ) if it was explicitly there.
            $term = ',' unless $term eq ')' || $term eq ';';
            if (exists $structs{$stype}) {
                my @fields = grep { !$_->{opaque} } @{$structs{$stype}};
                if (defined $array_range) {
                    # Array of structs: compute total packed width
                    my $struct_width = 0;
                    $struct_width += $_->{width} for @fields;
                    push @outbuf, "    $dir logic [$array_range] $port_name$term // $stype array (packed ${struct_width}b each)\n";
                } else {
                    # Expand each field as a separate port
                    for my $i (0 .. $#fields) {
                        my $f = $fields[$i];
                        my $sep = ($i == $#fields) ? $term : ',';
                        if ($f->{width} == 1) {
                            push @outbuf, "    $dir logic ${port_name}_$f->{name}$sep\n";
                        } else {
                            my $msb = $f->{width} - 1;
                            push @outbuf, "    $dir logic [$msb:0] ${port_name}_$f->{name}$sep\n";
                        }
                    }
                }
                next;
            }
        }

        # Replace enum-typed declarations with logic of appropriate width:
        # el2_inst_pkt_t name;  →  logic [3:0] name;
        if ($line =~ /^\s*(el2_\w+_t)\s+([\w,\s]+)\s*;/ && !exists $structs{$1}) {
            # Check if it's a known enum type — use 4-bit logic as default
            # (el2_inst_pkt_t is 4-bit, pmp types are 2-3 bit)
            my ($etype, $names_str) = ($1, $2);
            my $width = ($etype =~ /inst_pkt/) ? 4 : ($etype =~ /pmp_type/) ? 3 : ($etype =~ /pmp_mode/) ? 2 : 4;
            for my $name (split /\s*,\s*/, $names_str) {
                $name =~ s/^\s+|\s+$//g;
                next if $name eq '';
                push @outbuf, "  logic [${\($width-1)}:0] $name;\n";
            }
            next;
        }

        # Expand struct-typed signal/wire declarations in the body:
        # el2_br_pkt_t name;  →  logic name_valid; logic [11:0] name_toffset; ...
        # Also handles: el2_br_pkt_t name1, name2;
        if ($line =~ /^\s*(el2_\w+_t)\s+(.+?)\s*;/) {
            my ($stype, $names_str) = ($1, $2);
            if (exists $structs{$stype}) {
                my @fields = grep { !$_->{opaque} } @{$structs{$stype}};
                for my $sig_name (split /\s*,\s*/, $names_str) {
                    $sig_name =~ s/^\s+|\s+$//g;
                    next if $sig_name eq '';
                    for my $f (@fields) {
                        if ($f->{width} == 1) {
                            push @outbuf, "  logic ${sig_name}_$f->{name};\n";
                        } else {
                            my $msb = $f->{width} - 1;
                            push @outbuf, "  logic [$msb:0] ${sig_name}_$f->{name};\n";
                        }
                    }
                }
                next;
            }
        }

        # Strip #(.pt(pt)) from module instantiations
        $line =~ s/\s*#\(\s*\.pt\s*\(\s*pt\s*\)\s*\)//g;

        # Replace pt.FIELD with concrete integer values FIRST
        # (before generic struct.field → struct_field which would mangle them)
        if (%field_values) {
            $line =~ s/\b$param_name\.(\w+)\b/
                exists $field_values{$1} ? $field_values{$1} : "${param_name}_$1"
            /ge;
        }

        # Replace $clog2(N) with computed value
        $line =~ s/\$clog2\((\d+)\)/clog2($1)/ge;

        # Replace remaining struct.field access: signal.field → signal_field
        # (skip module declarations, comments, and port-map dots .name(expr))
        $line =~ s/(\w+)\.(\w+)\b(?!\s*\()/${1}_${2}/g
            if $line !~ /^\s*module\b/ && $line !~ /^\s*\/\//;

        push @outbuf, $line;
    }

    # Post-process: fix trailing comma before );
    for my $i (0 .. $#outbuf) {
        if ($outbuf[$i] =~ /^\s*\)\s*;/ && $i > 0) {
            # Remove trailing comma from previous non-blank line
            for my $j (reverse 0 .. $i-1) {
                next if $outbuf[$j] =~ /^\s*$/;
                $outbuf[$j] =~ s/,\s*$/\n/;
                last;
            }
        }
    }

    # Strip initial begin $fatal/$error ... end blocks (parameter validation)
    my $in_fatal = 0;
    for my $line (@outbuf) {
        if ($line =~ /^\s*initial\s+begin\s*$/ || $line =~ /\$fatal\b|\$error\b/) {
            $in_fatal = 1 if $line =~ /\$fatal|\$error/;
        }
        if ($in_fatal) {
            $line = "// stripped: $line" if $line !~ /^\s*$/;
            $in_fatal = 0 if $line =~ /^\s*end\s*$/;
            next;
        }
    }

    print @outbuf;
}

sub clog2 {
    my ($n) = @_;
    return 0 if $n <= 1;
    my $r = 0;
    $n--;
    while ($n > 0) { $n >>= 1; $r++; }
    return $r;
}
