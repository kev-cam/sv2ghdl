#!/bin/bash
#
# iverilog-sv2ghdl - iverilog-compatible wrapper for sv2ghdl + NVC
#
# Two-stage translation:
#   1. Try iverilog -tvhdl -psv2vhdl=1 (native VHDL backend with entity
#      instantiations for sv2vhdl primitives)
#   2. Fall back to sv2ghdl.pl (Perl translator) if that fails
#
# Designed to work with the iverilog test suite (vvp_reg.pl --suffix=-sv2ghdl).
#
# The output file (-o) is a directory containing translated VHDL, NVC's work
# library, and a _metadata file.  The test runner's "rm -rf ./vsim" cleans
# everything up between tests.
#

set -o pipefail
export PATH="/usr/bin:/usr/local/bin:/bin:$PATH"

# Resolve script directory using bash string ops (no external commands)
SCRIPT_DIR="${BASH_SOURCE[0]%/*}/.."
SV2GHDL="$SCRIPT_DIR/sv2ghdl.pl"

# Tool paths: prefer the BUILD-AREA binaries (validate what we build before
# install); fall back to PATH. $NVC / $IVERILOG still override.
if [[ -z "$NVC" ]]; then
    if [[ -x /usr/local/src/nvc-build/bin/nvc ]]; then
        NVC=/usr/local/src/nvc-build/bin/nvc
    else
        NVC=nvc
    fi
fi
if [[ -z "$IVERILOG" ]]; then
    if [[ -x /usr/local/src/iverilog/_install/bin/iverilog ]]; then
        IVERILOG=/usr/local/src/iverilog/_install/bin/iverilog
    else
        IVERILOG=iverilog
    fi
fi

# Several sv-normalize rewrites work around iverilog frontend limitations that a
# current iverilog no longer has, and that now do more harm than good:
#  - the chained-dynamic-index hoist (Rule 0/0b/0c, gotcha-c) is superseded by
#    native variable-prefix-index support (commit bb318c2be);
#  - Rule 1b's `assign struct.field` -> procedural rewrite is unnecessary (the
#    continuous form elaborates) and CREATES a proc-vs-continuous conflict when
#    the struct is also continuously driven (eh2_dec_tlu_top .tid).
# Probe the resolved iverilog ONCE (a variable prefix index errors on an
# unpatched build); if it has the modern frontend, disable both superseded
# rewrites so the core does the work. Each env var honours an explicit override.
if [[ -z "${SV_NORMALIZE_NO_CHAINED+x}" || -z "${SV_NORMALIZE_NO_STRUCT_ASSIGN+x}" ]]; then
    _vpx=$(mktemp -d)
    printf 'module _vpx; logic [3:0][7:0] a; integer r; wire [3:0] y = a[r][3:0]; endmodule\n' > "$_vpx/p.v"
    if "$IVERILOG" -g2012 -tnull -o /dev/null "$_vpx/p.v" >/dev/null 2>&1; then
        [[ -z "${SV_NORMALIZE_NO_CHAINED+x}" ]]       && export SV_NORMALIZE_NO_CHAINED=1
        [[ -z "${SV_NORMALIZE_NO_STRUCT_ASSIGN+x}" ]] && export SV_NORMALIZE_NO_STRUCT_ASSIGN=1
    fi
    rm -rf "$_vpx"
fi

# Derive NVC library path from binary location.
# Build tree:  .../nvc-build/bin/nvc -> .../nvc-build/lib
# Installed:   /usr/local/bin/nvc   -> /usr/local/lib/nvc
if [[ -z "$NVC_LIBDIR" ]]; then
    _nvc_bin=$(command -v "$NVC" 2>/dev/null)
    if [[ -n "$_nvc_bin" ]]; then
        _nvc_bin=$(readlink -f "$_nvc_bin")
        _nvc_prefix="${_nvc_bin%/bin/nvc}"
        # Check build-tree layout first (lib/sv2vhdl/ sibling to bin/)
        if [[ -d "$_nvc_prefix/lib/sv2vhdl" ]]; then
            NVC_LIBDIR="$_nvc_prefix/lib"
        # Installed layout: /usr/local/lib/nvc/sv2vhdl/
        elif [[ -d "$_nvc_prefix/lib/nvc/sv2vhdl" ]]; then
            NVC_LIBDIR="$_nvc_prefix/lib/nvc"
        else
            NVC_LIBDIR="$_nvc_prefix/lib/nvc"
        fi
    else
        NVC_LIBDIR="/usr/local/lib/nvc"
    fi
fi

# Defaults
OUTPUT="a.out"
TOP_MODULE=""
TARGET="vvp"
SOURCES=()
IVL_INC=()      # -I include dirs, forwarded to iverilog
IVL_DEF=()      # -D defines, forwarded to iverilog
ORIG_DIR="$(pwd)"

# Parse arguments (iverilog-compatible)
while [[ $# -gt 0 ]]; do
    case "$1" in
        -o)
            OUTPUT="$2"; shift 2 ;;
        -s)
            TOP_MODULE="$2"; shift 2 ;;
        -t)
            TARGET="$2"; shift 2 ;;
        -V)
            echo "Icarus Verilog version 13.0 (sv2ghdl/nvc)"
            exit 0 ;;
        -g*)    shift ;;   # Generation flags - ignored
        -D)     IVL_DEF+=("-D$2"); shift 2 ;;  # Define (separate arg)
        -D*)    IVL_DEF+=("$1");   shift ;;    # Define - forward to iverilog
        -I)     IVL_INC+=("-I$2"); shift 2 ;;  # Include dir (separate arg)
        -I*)    IVL_INC+=("$1");   shift ;;    # Include path - forward to iverilog
        -P*)    shift ;;   # Parameter overrides - ignored
        -W*)    shift ;;   # Warnings - ignored
        -S)     shift ;;   # Synthesize - ignored
        -v)     shift ;;   # Verbose - ignored
        -u)     shift ;;   # Separate compilation units - ignored
        -m)     shift 2 ;; # Module - ignored
        -m*)    shift ;;
        -L)     shift 2 ;; # Library path - ignored
        -L*)    shift ;;
        -y)     shift 2 ;; # Library dir - ignored
        -y*)    shift ;;
        -B)     shift 2 ;; # Tool path - ignored
        -B*)    shift ;;
        -p*)    shift ;;   # Compiler param - ignored
        -E)     shift ;;   # Preprocess only - ignored
        -*)     shift ;;   # Any other flag - ignored
        *)
            SOURCES+=("$1"); shift ;;
    esac
done

if [[ ${#SOURCES[@]} -eq 0 ]]; then
    echo "iverilog-sv2ghdl: no source files" >&2
    exit 1
fi

# Convert source paths to absolute before we cd
ABS_SOURCES=()
for src in "${SOURCES[@]}"; do
    case "$src" in
        /*) ABS_SOURCES+=("$src") ;;
        *)  ABS_SOURCES+=("$ORIG_DIR/$src") ;;
    esac
done

# Convert -I include dirs to absolute too — the iverilog calls below run after
# a cd into the output dir, so relative include paths would otherwise break.
ABS_INC=()
for inc in "${IVL_INC[@]}"; do
    dir="${inc#-I}"
    case "$dir" in
        /*) ABS_INC+=("-I$dir") ;;
        *)  ABS_INC+=("-I$ORIG_DIR/$dir") ;;
    esac
done

# Output directory (replaces the normal output file)
# The test runner's "rm -rf ./vsim" cleans this up between tests.
case "$OUTPUT" in
    /*) OUTDIR="$OUTPUT" ;;
    *)  OUTDIR="$ORIG_DIR/$OUTPUT" ;;
esac
rm -rf "$OUTDIR"
mkdir -p "$OUTDIR"

# --- Stage 0: preprocess + normalize ---
# The iverilog tgt-vhdl elaborator rejects some SystemVerilog the VeeR-class
# RTL uses (notably chained dynamic-then-range indexing `arr[VAR][HI:LO]`).
# sv-normalize rewrites those into translatable equivalents. The intended
# pipeline is `iverilog -E | sv-normalize | (translate)`, so do that here and
# feed the single normalized file to both stage 1 and the stage-2 split.
SV_NORMALIZE="${BASH_SOURCE[0]%/*}/sv-normalize"
NORM_SRC=""
if [[ -x "$SV_NORMALIZE" ]]; then
    _pp="$OUTDIR/_pp.v"
    _norm="$OUTDIR/_norm.sv"
    if "$IVERILOG" -E -g2012 "${ABS_INC[@]}" "${IVL_DEF[@]}" \
            -o "$_pp" "${ABS_SOURCES[@]}" 2>/dev/null \
       && [[ -s "$_pp" ]] \
       && "$SV_NORMALIZE" < "$_pp" > "$_norm" 2>/dev/null \
       && [[ -s "$_norm" ]]; then
        NORM_SRC="$_norm"
    fi
fi
# If normalization succeeded, translate the normalized file; otherwise fall
# back to the raw sources (preserves previous behaviour for simple inputs).
if [[ -n "$NORM_SRC" ]]; then
    XLAT_SOURCES=("$NORM_SRC")
else
    XLAT_SOURCES=("${ABS_SOURCES[@]}")
fi

IVERILOG_OK=0
VHDL_OUT="$OUTDIR/design.vhd"

# --- Stage 1a: sv2vhdl-modules on the normalized source ---
# sv2vhdl-modules does robust per-module translation (keeping each module's
# context) and emits a single combined design.vhd. This is the pipeline that
# translates whole VeeR-class designs; prefer it when we have a normalized
# source and the tool is available.
SV2VHDL_MODULES="${BASH_SOURCE[0]%/*}/sv2vhdl-modules"
SV_DEDUP="${BASH_SOURCE[0]%/*}/sv-dedup-vhdl"
if [[ -n "$NORM_SRC" && -x "$SV2VHDL_MODULES" ]]; then
    _mods="$OUTDIR/_mods.vhd"
    if IVERILOG="$IVERILOG" "$SV2VHDL_MODULES" "$NORM_SRC" -o "$_mods" 2>/dev/null \
            && [[ -s "$_mods" ]]; then
        # sv2vhdl-modules emits each parameterised helper (rvdff, rvdffe, ...)
        # once per referencing module; the same __hash variant therefore
        # appears many times. Deduplicate identical entity/architecture
        # definitions so NVC sees each variant once.
        if [[ -x "$SV_DEDUP" ]] && "$SV_DEDUP" < "$_mods" > "$VHDL_OUT" 2>/dev/null \
                && [[ -s "$VHDL_OUT" ]]; then
            :
        else
            cp "$_mods" "$VHDL_OUT"
        fi
        cd "$OUTDIR"
        if $NVC -M 2g -H 1g --std=2040 -L "$NVC_LIBDIR" -a "$VHDL_OUT" 2>&1; then
            IVERILOG_OK=1
            echo "SV2VHDL_MODULES=1" >> "$OUTDIR/_metadata.tmp"
        fi
        cd "$ORIG_DIR"
    fi
fi

# --- Stage 1: Try iverilog -tvhdl -psv2vhdl=1 ---
# Produces a single VHDL file with entity instantiations for sv2vhdl
# primitives.  Uses --std=2040 for NVC compilation.

if [[ $IVERILOG_OK -eq 0 ]] && \
   timeout 30 "$IVERILOG" -tvhdl -psv2vhdl=1 -g2012 "${ABS_INC[@]}" "${IVL_DEF[@]}" -o "$VHDL_OUT" "${XLAT_SOURCES[@]}" 2>/dev/null; then
    if [[ -s "$VHDL_OUT" ]]; then
        # Compile with NVC (--std=2040 for sv2vhdl library + STD_MX features)
        cd "$OUTDIR"
        if $NVC -M 2g -H 1g --std=2040 -L "$NVC_LIBDIR" -a "$VHDL_OUT" 2>&1; then
            IVERILOG_OK=1
            echo "IVERILOG_BACKEND=1" >> "$OUTDIR/_metadata.tmp"
        fi
    fi
fi

# --- Stage 2: Try iverilog per-module ---
# Split the source into individual modules and try iverilog on each one.
# This handles files where some modules translate but others don't.

if [[ $IVERILOG_OK -eq 0 ]]; then
    rm -f "$VHDL_OUT"
    rm -rf "$OUTDIR/work"

    SPLIT_DIR="$OUTDIR/_split"
    mkdir -p "$SPLIT_DIR"
    MODULES_OK=0
    MODULES_FAIL=0

    # Collect defines/timescale/includes across ALL source files into a
    # shared preamble, then split each file's modules into individual .v
    # files with that preamble prepended.  This mirrors Verilog's "one long
    # stream" compilation model where `defines are sticky.
    PREAMBLE_FILE="$SPLIT_DIR/_preamble.v"
    : > "$PREAMBLE_FILE"

    for src in "${XLAT_SOURCES[@]}"; do
        awk '
            /^\s*`timescale/ { print >> "'"$PREAMBLE_FILE"'"; next }
            /^\s*`define/    { print >> "'"$PREAMBLE_FILE"'"; next }
            /^\s*`include/   { print >> "'"$PREAMBLE_FILE"'"; next }
            /^\s*module\s+/ {
                if (out) close(out)
                match($0, /module\s+([a-zA-Z_][a-zA-Z0-9_]*)/, m)
                modname = m[1]
                out = "'"$SPLIT_DIR"'/" modname ".v"
                system("cat '"$PREAMBLE_FILE"' > " out)
            }
            { if (out) print >> out }
        ' "$src"
    done

    # Try iverilog on each module, validate with nvc -a, fall back to sv2ghdl.pl
    cd "$OUTDIR"
    for mod_v in "$SPLIT_DIR"/*.v; do
        [[ -f "$mod_v" ]] || continue
        modname="${mod_v##*/}"
        modname="${modname%.v}"
        [[ "$modname" == "_preamble" ]] && continue
        mod_vhd="$OUTDIR/${modname}.vhd"

        if timeout 30 "$IVERILOG" -tvhdl -psv2vhdl=1 -g2012 "${ABS_INC[@]}" "${IVL_DEF[@]}" \
                -o "$mod_vhd" "$mod_v" 2>/dev/null \
                && [[ -s "$mod_vhd" ]] \
                && $NVC --std=2040 -L "$NVC_LIBDIR" -a "$mod_vhd" >/dev/null 2>&1; then
            MODULES_OK=$((MODULES_OK + 1))
        else
            # iverilog failed or produced invalid VHDL — try sv2ghdl.pl
            rm -f "$mod_vhd"
            if "$SV2GHDL" "$mod_v" -o "$mod_vhd" 2>/dev/null \
                    && [[ -s "$mod_vhd" ]] \
                    && $NVC --std=2040 -L "$NVC_LIBDIR" -a "$mod_vhd" >/dev/null 2>&1; then
                MODULES_OK=$((MODULES_OK + 1))
            else
                rm -f "$mod_vhd"
                MODULES_FAIL=$((MODULES_FAIL + 1))
            fi
        fi
    done

    rm -rf "$SPLIT_DIR"

    if [[ $MODULES_OK -eq 0 ]]; then
        echo "iverilog-sv2ghdl: no modules translated" >&2
        exit 1
    fi
fi

# For -t null (CN tests), compilation is all we need
if [[ "$TARGET" == "null" ]]; then
    exit 0
fi

# Determine top entity. Auto-detect the RTL root: the top module is the one
# nothing else instantiates, so (with comments stripped) its name occurs only
# in its own `module <name>` declaration, while instantiated modules occur >=2
# times. Pick the unique minimum-occurrence module; fall back to the first
# module of the last source file if that's ambiguous.
if [[ -z "$TOP_MODULE" ]]; then
    _src=$(cat "${ABS_SOURCES[@]}" 2>/dev/null | sed -e 's://.*$::' -e 's:/\*.*\*/::g')
    _decl=$(printf '%s\n' "$_src" | grep -oP '^\s*(?:\(\*.*?\*\)\s*)*module\s+\K\w+' | sort -u)
    _best=""; _min=2147483647; _ties=0
    for _m in $_decl; do
        _c=$(printf '%s\n' "$_src" | grep -owE "$_m" | wc -l)
        if   (( _c < _min ));  then _min=$_c; _best="$_m"; _ties=1
        elif (( _c == _min )); then _ties=$((_ties + 1)); fi
    done
    (( _ties == 1 )) && TOP_MODULE="$_best"
fi
if [[ -z "$TOP_MODULE" ]]; then
    LAST_SOURCE="${ABS_SOURCES[${#ABS_SOURCES[@]}-1]}"
    TOP_MODULE=$(grep -m1 -oP '^\s*(?:\(\*.*?\*\)\s*)*module\s+\K\w+' "$LAST_SOURCE" 2>/dev/null)
fi

if [[ -z "$TOP_MODULE" ]]; then
    echo "iverilog-sv2ghdl: cannot determine top module" >&2
    exit 1
fi

# Write metadata for vvp-sv2ghdl
{
    echo "TOP_ENTITY=\"$TOP_MODULE\""
    if [[ $IVERILOG_OK -eq 1 ]]; then
        echo "NVC_STD=\"2040\""
    else
        echo "NVC_STD=\"2040\""
    fi
} > "$OUTDIR/_metadata"

exit 0
