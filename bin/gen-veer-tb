#!/usr/bin/env perl
# Emit a complete VeeR-EH1 testbench that drives the translated veer.
# Reads the entity declaration from the dedup'd VHDL output, auto-generates
# 1 signal per port + 1 entry in the port map. Adds clock/reset/cycle-count
# logic + a tiny AXI memory model for ifu/lsu reads (no writes mapped here
# beyond the magic mailbox at 0xD0580000).
#
# Usage: gen-veer-tb <vhdl_file>  > tb.vhd

use strict; use warnings;

my $file = shift @ARGV or die "Usage: gen-veer-tb <vhdl_file> [veer|veer_wrapper]\n";
my $top  = shift @ARGV || 'veer_wrapper';

open my $f, '<', $file or die "$file: $!";
my $in = 0; my @ports;
while (<$f>) {
    if (/^\s*entity\s+\Q$top\E\s+is\s*$/) { $in = 1; next; }
    if ($in) {
        last if /^\s*end\s+entity/;
        if (/^\s*(\w+)\s*:\s*(in|out|buffer|inout)\s+(.+?)[;,]?\s*$/) {
            push @ports, [ $1, $2, $3 ];
        }
    }
}
die "no $top ports parsed\n" unless @ports;

# Which ports are vectors (multi-bit). EH2/EL2 are multi-thread, so 1-bit-in-EH1
# control/status ports (e.g. mpc_reset_run_req, o_cpu_halt_status) become
# logic3d_vector(N-1 downto 0). The static tb template below assigns scalar
# L3D_1/L3D_0 and uses integer'image directly, which only type-checks for a
# scalar logic3d. Capture the generated tb and width-fix vector-port references
# afterwards: scalar reset value -> (others=>VALUE); integer'image(s_X) ->
# integer'image(l3d_to_nat(s_X)).
my %is_vec = map { $_->[0] => ($_->[2] =~ /_vector\b|\bdownto\b/ ? 1 : 0) } @ports;
my $TB_OUT = '';
open(my $__tbcap, '>', \$TB_OUT) or die "tb capture: $!\n";
my $__oldfh = select($__tbcap);

print <<'HEADER';
-- Auto-generated by gen-veer-tb.
library ieee;
use ieee.std_logic_1164.all;
use ieee.numeric_std.all;
use std.textio.all;

library sv2vhdl;
use sv2vhdl.logic3d_types_pkg.all;

entity veer_eh1_tb is
end entity;

architecture sim of veer_eh1_tb is
  constant MEM_BYTES : natural := 262144;
  type byte_mem_t is array (0 to MEM_BYTES-1) of integer range 0 to 255;
  signal mem : byte_mem_t := (others => 0);
  signal cycle_cnt : natural := 0;
  signal done      : boolean := false;

  -- VHDL `natural` is 31-bit, so a raw 32-bit address (e.g. mtvec at
  -- 0xee000000) would overflow r := r*2 once we shift past bit 30.
  -- Consume only the low 30 bits — sufficient for our 256KB memory.
  -- The high bits are surfaced via separate `addrhi` reports.
  function l3d_to_nat(v : logic3d_vector) return natural is
    variable r : natural := 0;
    variable top : natural := v'high;
  begin
    if top - v'low > 29 then top := v'low + 29; end if;
    for i in top downto v'low loop
      r := r * 2;
      if is_one(v(i)) then r := r + 1; end if;
    end loop;
    return r;
  end function;

  function nat_to_l3dv(n : natural; w : natural) return logic3d_vector is
    variable r  : logic3d_vector(w-1 downto 0) := (others => L3D_0);
    variable nn : natural := n;
  begin
    for i in 0 to w-1 loop
      if (nn mod 2) = 1 then r(i) := L3D_1; end if;
      nn := nn / 2;
    end loop;
    return r;
  end function;

HEADER

# Signal declarations
for my $p (@ports) {
    my ($n, $d, $t) = @$p;
    my $init = ($t =~ /vector\(/) ? "(others => L3D_0)" : "L3D_0";
    print "  signal s_$n : $t := $init;\n";
}
print "\nbegin\n";

# Clock
print <<'CLK';
  -- 100 MHz clock
  clk_proc: process
  begin
    while not done loop
      s_clk <= L3D_0; wait for 5 ns;
      s_clk <= L3D_1; wait for 5 ns;
    end loop;
    wait;
  end process;

  -- Reset: assert HIGH (L3D_1) first so async-reset rvdffs see the
  -- falling-edge transition when we drop to L3D_0. Without this, the
  -- registers never receive a `falling_edge(rst_l)` event and never
  -- get reset.
  rst_proc: process
  begin
    -- Phase 1: hold rst_l, dbg_rst_l HIGH for a couple cycles.
    s_rst_l            <= L3D_1;
    s_dbg_rst_l        <= L3D_1;
    s_mpc_reset_run_req<= L3D_1;
    wait for 20 ns;
    -- Phase 2: drop dbg_rst_l (falling-edge fires registered processes)
    s_dbg_rst_l        <= L3D_0;
    wait for 10 ns;
    -- Phase 3: drop rst_l (main reset assertion via falling edge)
    s_rst_l            <= L3D_0;
    wait for 50 ns;
    -- Phase 4: release dbg_rst_l, then rst_l
    s_dbg_rst_l        <= L3D_1;
    wait for 30 ns;
    s_rst_l            <= L3D_1;
    wait;
  end process;

  -- Cycle counter + periodic ping
  cyc_proc: process(s_clk)
  begin
    if rising_edge(s_clk) and is_one(s_rst_l) then
      cycle_cnt <= cycle_cnt + 1;
      if (cycle_cnt mod 50) = 0 then
        report "tick cycle=" & integer'image(cycle_cnt)
             & " rst_l="    & integer'image(s_rst_l)
             & " dbg_rst="  & integer'image(s_dbg_rst_l)
             & " halt="     & integer'image(s_o_cpu_halt_status)
             & " ifu_arv="  & integer'image(s_ifu_axi_arvalid)
             & " lsu_arv="  & integer'image(s_lsu_axi_arvalid);
      end if;
    end if;
  end process;

  -- Retire trace: architectural committed-instruction oracle (PC per slot).
  -- This is the reference stream for cross-simulator comparison (diffed
  -- instruction-for-instruction against Verilator's EXECUTION_TRACE exec.log)
  -- and for --accel stamp validation; do not remove.
  trace_proc: process(s_clk)
  begin
    if rising_edge(s_clk) and is_one(s_rst_l) then
      if l3d_to_nat(s_trace_rv_i_valid_ip) /= 0 then
        report "RETIRE cyc=" & integer'image(cycle_cnt)
             & " v=" & integer'image(l3d_to_nat(s_trace_rv_i_valid_ip))
             & " pc0=" & integer'image(l3d_to_nat(s_trace_rv_i_address_ip(31 downto 0)))
             & " pc1=" & integer'image(l3d_to_nat(s_trace_rv_i_address_ip(63 downto 32)));
      end if;
    end if;
  end process;

  -- Default ack signals high so AXI handshakes complete in one cycle
  s_lsu_axi_awready <= L3D_1;
  s_lsu_axi_wready  <= L3D_1;
  s_lsu_axi_arready <= L3D_1;
  s_ifu_axi_awready <= L3D_1;
  s_ifu_axi_wready  <= L3D_1;
  s_ifu_axi_arready <= L3D_1;
  s_sb_axi_awready  <= L3D_1;
  s_sb_axi_wready   <= L3D_1;
  s_sb_axi_arready  <= L3D_1;
  -- Bus clock enables: tick the AXI bus subsystems on every cycle.
  s_lsu_bus_clk_en  <= L3D_1;
  s_ifu_bus_clk_en  <= L3D_1;
  s_dbg_bus_clk_en  <= L3D_1;
  s_dma_bus_clk_en  <= L3D_1;
  -- IMPORTANT: scan_mode must be L3D_0 in normal sim.  Driving it high
  -- forces every rvclkhdr's enable latch (en_ff) permanently true, which
  -- bypasses clock-gating entirely -- causing every rvdffe in the design
  -- to update on every clock edge regardless of its own enable signal.
  -- That destroys per-instance gating; e.g. ifu_byp_data_first_half and
  -- ifu_byp_data_second_half both end up sampling the same AXI rdata
  -- on every cycle, so the bypass data fed to decode never matches the
  -- in-flight fetch's address.
  s_scan_mode       <= L3D_0;
CLK
if ($top eq 'veer') {
    # When DUT = veer (bare core, no memory subsystem) we need to drive
    # the icache memory interface ourselves and tie off the closely-
    # coupled memories.
    print <<'VEER_ONLY';
  -- DCCM/ICCM read data: leave at zero (no closely-coupled memory)
  s_dccm_rd_data_lo <= (others => L3D_0);
  s_dccm_rd_data_hi <= (others => L3D_0);
  s_iccm_rd_data    <= (others => L3D_0);

  -- Plug in the translated `ifu_ic_mem` so cache writes/reads behave
  -- correctly (this lives inside mem.sv which veer_wrapper wraps, but
  -- bare veer does not include it).
  icache: entity work.ifu_ic_mem
    port map (
      free_clk                 => s_clk,
      clk                      => s_clk,
      rst_l                    => s_rst_l,
      clk_override             => L3D_0,
      dec_tlu_core_ecc_disable => s_dec_tlu_core_ecc_disable,
      ic_rw_addr               => s_ic_rw_addr,
      ic_wr_en                 => s_ic_wr_en,
      ic_rd_en                 => s_ic_rd_en,
      ic_debug_addr            => s_ic_debug_addr,
      ic_debug_rd_en           => s_ic_debug_rd_en,
      ic_debug_wr_en           => s_ic_debug_wr_en,
      ic_debug_tag_array       => s_ic_debug_tag_array,
      ic_debug_way             => s_ic_debug_way,
      ic_premux_data           => s_ic_premux_data,
      ic_sel_premux_data       => s_ic_sel_premux_data,
      ic_wr_data               => s_ic_wr_data,
      ic_rd_data               => s_ic_rd_data,
      ictag_debug_rd_data      => s_ictag_debug_rd_data,
      ic_debug_wr_data         => s_ic_debug_wr_data,
      ic_tag_valid             => s_ic_tag_valid,
      ic_rd_hit                => s_ic_rd_hit,
      ic_tag_perr              => s_ic_tag_perr,
      scan_mode                => s_scan_mode
    );

VEER_ONLY
}
print <<'CLK';
  -- Load program.hex into mem
  load_proc: process
    file f : text;
    variable l : line;
    variable c : character;
    variable nyb, b : integer;
    variable have_nyb : boolean;
    variable addr : natural := 0;
    variable st : file_open_status;
  begin
    file_open(st, f, "program.hex", read_mode);
    if st /= open_ok then
      report "could not open program.hex" severity warning;
    else
      while not endfile(f) loop
        readline(f, l);
        have_nyb := false;
        nyb := 0;
        -- `@HEXADDR` lines reset the load address; without this the
        -- hex digits of the address get parsed as zero bytes and shift
        -- the entire program forward.
        if l'length > 0 and l(l'left) = '@' then
          read(l, c);  -- consume '@'
          addr := 0;
          while l'length > 0 loop
            read(l, c);
            case c is
              when '0' to '9' => b := character'pos(c) - character'pos('0');
              when 'a' to 'f' => b := character'pos(c) - character'pos('a') + 10;
              when 'A' to 'F' => b := character'pos(c) - character'pos('A') + 10;
              when others     => b := -1;
            end case;
            exit when b < 0;
            addr := addr * 16 + b;
          end loop;
        end if;
        while l'length > 0 loop
          read(l, c);
          case c is
            when '0' to '9' => b := character'pos(c) - character'pos('0');
            when 'a' to 'f' => b := character'pos(c) - character'pos('a') + 10;
            when 'A' to 'F' => b := character'pos(c) - character'pos('A') + 10;
            when others     => b := -1;
          end case;
          if b >= 0 then
            if have_nyb then
              if addr < MEM_BYTES then
                mem(addr) <= nyb*16 + b;
                addr := addr + 1;
              end if;
              have_nyb := false;
            else
              nyb := b;
              have_nyb := true;
            end if;
          end if;
        end loop;
      end loop;
      file_close(f);
      report "loaded " & integer'image(addr) & " bytes from program.hex";
    end if;
    wait;
  end process;

  -- IFU read response.
  --
  -- AXI handshake state with configurable latency.  The IFU expects a
  -- realistic memory latency: same-cycle responses cause races against
  -- the IFU's internal pipeline (rdata_ff gets overwritten before the
  -- bypass path can consume it).  We use a small FIFO of pending
  -- requests and drive rvalid LATENCY cycles after the AR handshake.
  ifu_resp: process(s_clk)
    constant DEPTH    : natural := 8;
    constant LATENCY  : natural := 2;  -- cycles AR→R
    type q_addr_t is array (0 to DEPTH-1) of natural;
    type q_id_t   is array (0 to DEPTH-1) of logic3d_vector(2 downto 0);
    type q_age_t  is array (0 to DEPTH-1) of natural;
    variable q_addr : q_addr_t;
    variable q_id   : q_id_t   := (others => (others => L3D_0));
    variable q_age  : q_age_t  := (others => 0);
    variable q_valid : std_logic_vector(0 to DEPTH-1) := (others => '0');
    variable a : natural;
    variable d : logic3d_vector(63 downto 0);
    variable rdata_live : boolean := false;
  begin
    if rising_edge(s_clk) then
      -- Drop rvalid once the consumer acks it.
      if rdata_live and is_one(s_ifu_axi_rready) then
        s_ifu_axi_rvalid <= L3D_0;
        s_ifu_axi_rlast  <= L3D_0;
        rdata_live := false;
      end if;
      -- Enqueue a new request on arvalid+arready handshake.
      if is_one(s_rst_l) and is_one(s_ifu_axi_arvalid)
         and is_one(s_ifu_axi_arready) then
        for i in 0 to DEPTH-1 loop
          if q_valid(i) = '0' then
            q_valid(i) := '1';
            q_addr(i) := l3d_to_nat(s_ifu_axi_araddr);
            q_id(i)   := s_ifu_axi_arid;
            q_age(i)  := 0;
            report "IFU AR cycle=" & integer'image(cycle_cnt)
                 & " addr=" & integer'image(q_addr(i));
            exit;
          end if;
        end loop;
      end if;
      -- Age all pending requests; service the oldest that's reached LATENCY.
      for i in 0 to DEPTH-1 loop
        if q_valid(i) = '1' then q_age(i) := q_age(i) + 1; end if;
      end loop;
      if not rdata_live then
        for i in 0 to DEPTH-1 loop
          if q_valid(i) = '1' and q_age(i) >= LATENCY then
            a := q_addr(i);
            d := (others => L3D_0);
            if a + 7 < MEM_BYTES then
              for k in 0 to 7 loop
                d(k*8+7 downto k*8) := nat_to_l3dv(mem(a+k), 8);
              end loop;
            end if;
            s_ifu_axi_rdata  <= d;
            s_ifu_axi_rid    <= q_id(i);
            s_ifu_axi_rvalid <= L3D_1;
            s_ifu_axi_rlast  <= L3D_1;
            rdata_live := true;
            q_valid(i) := '0';
            exit;
          end if;
        end loop;
      end if;
    end if;
  end process;

  -- LSU read response: drive rvalid/rdata COMBINATIONALLY from arvalid.
  -- The bus_buffer's lsu_axi_rdata_ff is gated by a TEC_RV_ICG cell whose
  -- enable latches on the falling edge — so rvalid must already be high
  -- *before* the next rising edge for rdata_q to capture this cycle.  If
  -- we drive rvalid in a clocked process, the `<=` delta delay slips the
  -- enable past the rising edge and rdata_q lands one cycle too late;
  -- by then buf_state has already advanced RESP→DONE and the load result
  -- never makes it into buf_data.  Pure combinational drive matches the
  -- typical zero-latency-AXI testbench behaviour and lets the data
  -- propagate during the bus_buffer's RESP cycle.
  lsu_rd_resp: process(all)
    variable a : natural;
    variable d : logic3d_vector(63 downto 0);
  begin
    s_lsu_axi_rdata  <= (others => L3D_0);
    s_lsu_axi_rid    <= (others => L3D_0);
    s_lsu_axi_rvalid <= L3D_0;
    s_lsu_axi_rlast  <= L3D_0;
    if is_one(s_rst_l) and is_one(s_lsu_axi_arvalid) then
      a := l3d_to_nat(s_lsu_axi_araddr);
      d := (others => L3D_0);
      if a + 7 < MEM_BYTES then
        for i in 0 to 7 loop
          d(i*8+7 downto i*8) := nat_to_l3dv(mem(a+i), 8);
        end loop;
      end if;
      s_lsu_axi_rdata  <= d;
      s_lsu_axi_rid    <= s_lsu_axi_arid;
      s_lsu_axi_rvalid <= L3D_1;
      s_lsu_axi_rlast  <= L3D_1;
    end if;
  end process;

  -- LSU writes + AR-report (clocked for the write side; the read response
  -- above runs combinationally so it can satisfy the rdata_ff timing).
  lsu_resp: process(s_clk)
    variable a : natural;
    variable wb : natural;
  begin
    if rising_edge(s_clk) and is_one(s_rst_l) then
      if is_one(s_lsu_axi_arvalid) then
        report "LSU AR cyc=" & integer'image(cycle_cnt)
             & " addrlo=" & integer'image(l3d_to_nat(s_lsu_axi_araddr(23 downto 0)))
             & " addrhi=" & integer'image(l3d_to_nat(s_lsu_axi_araddr(31 downto 24)));
      end if;

      -- Write (handshake on awvalid)
      if is_one(s_lsu_axi_awvalid) and is_one(s_lsu_axi_wvalid) then
        wb := l3d_to_nat(s_lsu_axi_wdata(7 downto 0));
        -- Mailbox magic at 0xD0580000: compare upper 16 bits separately
        -- (full 32-bit address overflows VHDL `natural`).
        if l3d_to_nat(s_lsu_axi_awaddr(31 downto 16)) = 16#D058# then
          if wb = 16#FF# then
            report "TEST_PASSED  cycles=" & integer'image(cycle_cnt);
            done <= true;
          elsif wb = 16#01# then
            report "TEST_FAILED  cycles=" & integer'image(cycle_cnt);
            done <= true;
          else
            -- printable byte? echo via report
            if wb >= 32 and wb < 127 then
              report "stdout: " & character'val(wb);
            end if;
          end if;
        else
          a := l3d_to_nat(s_lsu_axi_awaddr(17 downto 0));  -- low 18 bits
          if a + 7 < MEM_BYTES then
            for i in 0 to 7 loop
              if is_one(s_lsu_axi_wstrb(i)) then
                mem(a+i) <= l3d_to_nat(s_lsu_axi_wdata(i*8+7 downto i*8));
              end if;
            end loop;
          end if;
        end if;
        s_lsu_axi_bvalid <= L3D_1;
        s_lsu_axi_bid    <= s_lsu_axi_awid;
      elsif is_one(s_lsu_axi_bready) then
        s_lsu_axi_bvalid <= L3D_0;
      end if;
    end if;
  end process;

  -- RTLMeter contract: emit the simulated cycle count to
  -- _rtlmeter_cycles.txt when the run completes (TEST_PASSED/FAILED set
  -- `done`). RTLMeter reads this file for its cycle metric; without it a
  -- correct run is still scored as failed ("no .prn"/no cycles).
  cycles_out: process(done)
    file fcyc : text;
    variable lcyc : line;
    variable st : file_open_status;
  begin
    if done then
      file_open(st, fcyc, "_rtlmeter_cycles.txt", write_mode);
      if st = open_ok then
        write(lcyc, cycle_cnt);
        writeline(fcyc, lcyc);
        file_close(fcyc);
        report "wrote _rtlmeter_cycles.txt = " & integer'image(cycle_cnt);
      end if;
    end if;
  end process;

  -- Watchdog
  wd: process
  begin
    wait for 1 ms;
    if not done then
      report "WATCHDOG: 1ms reached, cycles=" & integer'image(cycle_cnt) severity failure;
    end if;
    wait;
  end process;

CLK

# Port map
print "  -- DUT instantiation\n  dut : entity work.$top port map (\n";
my $i = 0;
for my $p (@ports) {
    my ($n) = @$p;
    my $sep = (++$i == @ports) ? "" : ",";
    print "    $n => s_$n$sep\n";
}
print "  );\nend architecture;\n";

# --- width-fix vector-port references, then emit ---
select($__oldfh);
close($__tbcap);
# Size the IFU read-id queue (q_id_t) to the real ifu_axi_rid/arid width: the
# template hardcodes logic3d_vector(2 downto 0) (EH1's 3-bit AXI ID), but EH2's
# dual-thread ID is 4-bit. Derive the high bound from the actual port.
my %ptype = map { $_->[0] => $_->[2] } @ports;
if ((($ptype{ifu_axi_rid} // $ptype{ifu_axi_arid}) // '') =~ /\((\d+)\s+downto\s+0\)/) {
    my $hi = $1;
    $TB_OUT =~ s/(array \(0 to DEPTH-1\) of logic3d_vector\()2( downto 0\))/$1$hi$2/g
        if $hi != 2;
}
for my $p (@ports) {
    my ($n) = @$p;
    next unless $is_vec{$n};
    # scalar reset assignment -> aggregate: s_X <= L3D_1;  ->  s_X <= (others => L3D_1);
    $TB_OUT =~ s/(\bs_\Q$n\E\s*<=\s*)(L3D_[01])(\s*;)/$1(others => $2)$3/g;
    # integer'image on a vector -> reduce to natural first
    $TB_OUT =~ s/integer'image\(\s*s_\Q$n\E\s*\)/integer'image(l3d_to_nat(s_$n))/g;
}
print $TB_OUT;
